
#define AIN1 12
#define AIN2 13
#define PWMA 4

#define BIN1 14
#define BIN2 27
#define PWMB 2

#define STBY 23

void setup() {

pinMode(AIN1, OUTPUT);
pinMode(AIN2, OUTPUT);
pinMode(PWMA, OUTPUT);

pinMode(BIN1, OUTPUT);
pinMode(BIN2, OUTPUT);
pinMode(PWMB, OUTPUT);

pinMode(STBY, OUTPUT);

digitalWrite(STBY, HIGH);

}

void loop() {

// vooruit

digitalWrite(AIN1, HIGH);
digitalWrite(AIN2, LOW);
analogWrite(PWMA, 150);

digitalWrite(BIN1, HIGH);
digitalWrite(BIN2, LOW);
analogWrite(PWMB, 150);

delay(2000);

// stop

analogWrite(PWMA, 0);
analogWrite(PWMB, 0);

delay(2000);
